# Supabase — get these from your Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never exposed to the browser.
# Used by the seed script and admin RPCs. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Domain used for the username -> synthetic email mapping (any value works,
# it never needs to receive mail). e.g. hoops.local
NEXT_PUBLIC_APP_EMAIL_DOMAIN=hoops.local
